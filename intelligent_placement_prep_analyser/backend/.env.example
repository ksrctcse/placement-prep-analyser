# Environment Configuration for Placement Prep Analyser

# ========================================
# DATABASE Configuration
# ========================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/database

# SQLAlchemy options
SQLALCHEMY_ECHO=False
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10

# ========================================
# JWT (JSON Web Token) Configuration
# ========================================
JWT_SECRET=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# API Configuration
# ========================================
API_TITLE=AI Academic Performance Analyzer
API_VERSION=1.0.0

# ========================================
# LLM & AI Configuration (REQUIRED for RAG/Semantic Search)
# ========================================
# Get your Google API key from: https://aistudio.google.com/app/apikey
# This is REQUIRED for PDF semantic indexing and vector embeddings
GOOGLE_API_KEY=your-google-api-key-here

# LangChain API key (optional, for advanced features)
LANGCHAIN_API_KEY=your-langchain-api-key-optional

# ========================================
# Setup Instructions
# ========================================
# 1. Copy this file to .env (remove .example)
#    $ cp .env.example .env
#
# 2. Update the values with your actual credentials:
#    - DATABASE_URL: Your PostgreSQL connection string
#    - GOOGLE_API_KEY: Get from https://makersuite.google.com/app/apikey
#    - JWT_SECRET: A strong random string for token signing
#
# 3. Save the .env file and restart your application
#
# Important: Never commit .env file to version control!
# Add .env to .gitignore
