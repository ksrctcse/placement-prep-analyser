# Environment Configuration Template
# Copy this file to .env and fill in the appropriate values

# API Configuration
DEBUG=True
APP_NAME="Placement Prep Analyser"

# Database Configuration
# For SQLite (development):
DATABASE_URL=sqlite:///placement.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@localhost:5432/placement_db

# JWT Configuration
JWT_SECRET=placement_secret_key_change_in_production_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Gemini API Configuration
# Get your API key from: https://cloud.google.com/generative-ai/docs/apis
GEMINI_API_KEY=your_gemini_api_key_here

# Vector Store Configuration
# Options: chromadb or faiss
VECTOR_STORE_TYPE=chromadb
VECTOR_STORE_PATH=./vector_store

# CORS Configuration
# Add your frontend URLs here for production
ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Configuration (optional, for future email notifications)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# File Upload Configuration
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Logging Configuration
LOG_LEVEL=INFO
